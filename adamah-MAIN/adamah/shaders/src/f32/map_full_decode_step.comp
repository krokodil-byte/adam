#if defined(ADAMAH_PROFILE_BROADCOM_V3DV_BALANCED) || defined(ADAMAH_PROFILE_BROADCOM_V3DV_NARROW)
#define ADAMAH_V3D_MONOLITHIC 1
#else
#define ADAMAH_V3D_MONOLITHIC 0
#endif

#if !ADAMAH_V3D_MONOLITHIC
#extension GL_EXT_buffer_reference : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require
#endif

#if ADAMAH_V3D_MONOLITHIC
#ifndef ADAMAH_FULL_DECODE_WG_SIZE
#define ADAMAH_FULL_DECODE_WG_SIZE 256
#endif
#define WG_SIZE ADAMAH_FULL_DECODE_WG_SIZE
#define ADAMAH_USE_SUBGROUP_REDUCE 0
#else
#define WG_SIZE 128
// Keep tree-reduce path as default for broad compatibility across profile
// compilers (some stacks reject subgroup reductions unless SPIR-V >= 1.3).
#define ADAMAH_USE_SUBGROUP_REDUCE 0
#endif

#if ADAMAH_USE_SUBGROUP_REDUCE
#extension GL_KHR_shader_subgroup_basic : require
#extension GL_KHR_shader_subgroup_arithmetic : require
#endif
#define ADAMAH_FULL_DECODE_MAX_LAYERS 26

// Tuned for Gemma3-1B decode path. Guarded at runtime against larger shapes.
#define MAX_EMBD 2048u
#define MAX_TMP 9216u
#define MAX_HEAD_DIM 512u
#define MAX_GROUP_SUM 288u

layout(local_size_x = WG_SIZE) in;

#if ADAMAH_V3D_MONOLITHIC
#define ADDR_T uvec2
#define SEL_WS_F32 0u
#define SEL_Q8_MAIN 1u
#define SEL_Q8_B12 2u
#define SEL_Q5_RAW 3u
#define SEL_Q4_MAIN 4u
#else
#define ADDR_T uint64_t
layout(buffer_reference, std430) readonly buffer Q8Buf { uint8_t b[]; };
layout(buffer_reference, std430) readonly buffer QPBuf { float f[]; };
layout(buffer_reference, std430) readonly buffer F32Buf { float f[]; };
#endif

