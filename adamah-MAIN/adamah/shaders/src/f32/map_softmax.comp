#version 450

#ifdef ADAMAH_PROFILE_BROADCOM_V3DV_NARROW
#define WG_SM 32
#elif defined(ADAMAH_PROFILE_BROADCOM_V3DV_BALANCED)
#define WG_SM 64
#else
#define WG_SM 256
#endif

layout(local_size_x = WG_SM) in;

layout(push_constant) uniform PushConstants {
    uint n_rows;
    uint row_size;
} pc;

layout(set = 0, binding = 0) buffer MapBuffer { float data[]; };
layout(set = 0, binding = 1) buffer SrcLocs { uint locs_src[]; };
layout(set = 0, binding = 2) buffer DstLocs { uint locs_dst[]; };

shared float sdata[WG_SM];

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint row_idx = gl_WorkGroupID.x;
    if (row_idx >= pc.n_rows) return;

    uint src_base = locs_src[row_idx] * pc.row_size;
    uint dst_base = locs_dst[row_idx] * pc.row_size;

    // Pass 1: find max
    float max_val = -9.99999968e+37;
    for (uint i = tid; i < pc.row_size; i += uint(WG_SM)) {
        max_val = max(max_val, data[src_base + i]);
    }
    sdata[tid] = max_val;
    barrier();

    for (uint s = uint(WG_SM >> 1); s > 0u; s >>= 1u) {
        if (tid < s) sdata[tid] = max(sdata[tid], sdata[tid + s]);
        barrier();
    }
    float row_max = sdata[0];
    barrier();

    // Pass 2: exp and sum
    float sum_val = 0.0;
    for (uint i = tid; i < pc.row_size; i += uint(WG_SM)) {
        float e = exp(data[src_base + i] - row_max);
        data[dst_base + i] = e;
        sum_val += e;
    }
    sdata[tid] = sum_val;
    barrier();

    for (uint s = uint(WG_SM >> 1); s > 0u; s >>= 1u) {
        if (tid < s) sdata[tid] += sdata[tid + s];
        barrier();
    }
    float row_sum = sdata[0];
    float inv_sum = 1.0 / row_sum;
    barrier();

    // Pass 3: normalize
    for (uint i = tid; i < pc.row_size; i += uint(WG_SM)) {
        data[dst_base + i] *= inv_sum;
    }
}
